// SQLite 兼容版 schema
// 注意：SQLite 不支持原生 enum 和 String[]，所以：
//   - 所有枚举类型用 String 代替，业务层通过 Zod/常量进行值校验
//   - 所有数组类型用 Json 代替，业务层 JSON.parse/stringify 处理

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                  Int       @id @default(autoincrement())
  username            String    @unique
  passwordHash        String
  realName            String
  phone               String?
  email               String?
  // Role: ADMIN | STORE_MANAGER | TECHNICIAN
  role                String
  storeId             Int?
  store               Store?    @relation(fields: [storeId], references: [id])
  isActive            Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  technician          TechnicianProfile?
  assignedTickets     RepairTicket[] @relation("AssignedTickets")
  createdTickets      RepairTicket[] @relation("CreatedTickets")
  createdLogs         OperationLog[]
  statusHistoryLogs   StatusHistory[]
  requestedParts      SparePartRequest[] @relation("Requester")
  approvedParts       SparePartRequest[] @relation("Approver")
  operatedTransfers   Transfer[]
  inventoryLogs       InventoryLog[]
  convertedSuggestions RestockSuggestion[] @relation("RestockConverter")
  createdPurchasePlans PurchasePlan[] @relation("PurchasePlanCreator")
  submittedPurchasePlans PurchasePlan[] @relation("PurchasePlanSubmitter")
  approvedPurchasePlans PurchasePlan[] @relation("PurchasePlanApprover")
  rejectedPurchasePlans PurchasePlan[] @relation("PurchasePlanRejector")
  cancelledPurchasePlans PurchasePlan[] @relation("PurchasePlanCanceller")
  createdPurchaseReceipts PurchaseReceipt[] @relation("PurchaseReceiptCreator")
  confirmedPurchaseReceipts PurchaseReceipt[] @relation("PurchaseReceiptConfirmer")
}

model TechnicianProfile {
  id            Int       @id @default(autoincrement())
  userId        Int       @unique
  user          User      @relation(fields: [userId], references: [id])
  // 技能列表，存储为 JSON.stringify 后的字符串："[\"空调维修\",\"制冷设备\"]"
  skills        String
  // 区域列表，存储为 JSON.stringify 后的字符串："[\"华东\",\"华北\"]"
  regions       String
  maxLoad       Int       @default(5)
  currentLoad   Int       @default(0)
  rating        Float     @default(0)
  completedCount Int      @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Store {
  id                      Int       @id @default(autoincrement())
  storeCode               String    @unique
  name                    String
  address                 String
  region                  String
  phone                   String?
  managerId               Int?
  isActive                Boolean   @default(true)
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  users                   User[]
  equipments              Equipment[]
  inventories             Inventory[]
  tickets                 RepairTicket[]
  sparePartRequestsFrom   SparePartRequest[] @relation("FromStoreTransfers")
  sparePartRequestsTo     SparePartRequest[] @relation("ToStoreTransfers")
  transfersFrom           Transfer[] @relation("TransferFromStore")
  transfersTo             Transfer[] @relation("TransferToStore")
  inventoryLogs           InventoryLog[]
  restockSuggestions      RestockSuggestion[]
  purchasePlans           PurchasePlan[]
  purchaseReceipts        PurchaseReceipt[]
}

model Equipment {
  id            Int       @id @default(autoincrement())
  equipmentCode String    @unique
  name          String
  model         String?
  category      String
  storeId       Int
  store         Store     @relation(fields: [storeId], references: [id])
  purchaseDate  DateTime?
  lastMaintenanceDate DateTime?
  status        String    @default("NORMAL")
  description   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  tickets       RepairTicket[]
}

model SlaRule {
  id            Int       @id @default(autoincrement())
  // urgency: LOW | MEDIUM | HIGH | URGENT
  urgency       String    @unique
  responseMinutes   Int
  resolutionMinutes Int
  escalationMinutes Int
  description   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model RepairTicket {
  id            Int       @id @default(autoincrement())
  ticketNo      String    @unique
  equipmentId   Int
  equipment     Equipment @relation(fields: [equipmentId], references: [id])
  storeId       Int
  store         Store     @relation(fields: [storeId], references: [id])
  faultType     String
  description   String
  // 图片 URL 列表，JSON.stringify 后的字符串数组
  imageUrls     String
  // urgency: LOW | MEDIUM | HIGH | URGENT
  urgency       String
  expectedTime  DateTime?
  // status: CREATED/ASSIGNED/... 共13+1种
  status        String    @default("CREATED")
  createdById   Int
  createdBy     User      @relation("CreatedTickets", fields: [createdById], references: [id])
  assignedToId  Int?
  assignedTo    User?     @relation("AssignedTickets", fields: [assignedToId], references: [id])
  diagnosis     String?
  repairResult  String?
  rejectReason  String?
  mergedTicketId Int?
  mergedTicket  RepairTicket? @relation("MergedTickets", fields: [mergedTicketId], references: [id])
  slaDeadline   DateTime?
  escalated     Boolean   @default(false)
  escalationReason String?
  arrivedAt     DateTime?
  completedAt   DateTime?
  acceptedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  statusHistory StatusHistory[]
  sparePartRequests SparePartRequest[]
  mergedChildren RepairTicket[] @relation("MergedTickets")
}

model StatusHistory {
  id            Int       @id @default(autoincrement())
  ticketId      Int
  ticket        RepairTicket @relation(fields: [ticketId], references: [id])
  // TicketStatus 字符串
  fromStatus    String?
  toStatus      String
  operatorId    Int
  operator      User      @relation(fields: [operatorId], references: [id])
  remark        String?
  createdAt     DateTime  @default(now())
}

model SparePart {
  id            Int       @id @default(autoincrement())
  partCode      String    @unique
  name          String
  category      String
  unit          String
  description   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  inventories             Inventory[]
  sparePartRequests       SparePartRequest[]
  transfers               Transfer[]
  inventoryLogs           InventoryLog[]
  restockSuggestions      RestockSuggestion[]
  purchasePlanItems       PurchasePlanItem[]
  purchaseReceiptItems    PurchaseReceiptItem[]
}

model Inventory {
  id            Int       @id @default(autoincrement())
  sparePartId   Int
  sparePart     SparePart @relation(fields: [sparePartId], references: [id])
  storeId       Int
  store         Store     @relation(fields: [storeId], references: [id])
  quantity      Int       @default(0)
  lockedQty     Int       @default(0)
  availableQty  Int       @default(0)
  minStock      Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  @@unique([sparePartId, storeId])
}

model SparePartRequest {
  id            Int       @id @default(autoincrement())
  requestNo     String    @unique
  ticketId      Int
  ticket        RepairTicket @relation(fields: [ticketId], references: [id])
  sparePartId   Int
  sparePart     SparePart @relation(fields: [sparePartId], references: [id])
  requestQty    Int
  fulfilledQty  Int       @default(0)
  // status: PENDING|APPROVED|REJECTED|PARTIAL_FULFILLED|FULL_FULFILLED|BACKORDER|CANCELLED
  status        String    @default("PENDING")
  fromStoreId   Int?
  fromStore     Store?    @relation("FromStoreTransfers", fields: [fromStoreId], references: [id])
  toStoreId     Int
  toStore       Store     @relation("ToStoreTransfers", fields: [toStoreId], references: [id])
  requestedById Int
  requestedBy   User      @relation("Requester", fields: [requestedById], references: [id])
  approvedById  Int?
  approvedBy    User?     @relation("Approver", fields: [approvedById], references: [id])
  remark        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  transfers     Transfer[]
}

model Transfer {
  id            Int       @id @default(autoincrement())
  transferNo    String    @unique
  requestId     Int
  request       SparePartRequest @relation(fields: [requestId], references: [id])
  sparePartId   Int
  sparePart     SparePart @relation(fields: [sparePartId], references: [id])
  fromStoreId   Int
  fromStore     Store     @relation("TransferFromStore", fields: [fromStoreId], references: [id])
  toStoreId     Int
  toStore       Store     @relation("TransferToStore", fields: [toStoreId], references: [id])
  quantity      Int
  // status: PENDING|IN_TRANSIT|RECEIVED|CANCELLED
  status        String    @default("PENDING")
  operatorId    Int
  operator      User      @relation(fields: [operatorId], references: [id])
  shippedAt     DateTime?
  receivedAt    DateTime?
  remark        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model InventoryLog {
  id                  Int       @id @default(autoincrement())
  sparePartId         Int
  sparePart           SparePart @relation(fields: [sparePartId], references: [id])
  storeId             Int
  store               Store     @relation(fields: [storeId], references: [id])
  changeType          String
  quantityBefore      Int
  quantityAfter       Int
  lockedQtyBefore     Int
  lockedQtyAfter      Int
  availableQtyBefore  Int
  availableQtyAfter   Int
  relatedTicketId     Int?
  relatedRequestId    Int?
  relatedTransferId   Int?
  relatedPurchasePlanId     Int?
  relatedPurchaseReceiptId  Int?
  operatorId          Int
  operator            User      @relation(fields: [operatorId], references: [id])
  remark              String?
  createdAt           DateTime  @default(now())

  purchasePlan     PurchasePlan?     @relation(fields: [relatedPurchasePlanId], references: [id])
  purchaseReceipt  PurchaseReceipt?  @relation(fields: [relatedPurchaseReceiptId], references: [id])
}

model RestockSuggestion {
  id              Int       @id @default(autoincrement())
  sparePartId     Int
  sparePart       SparePart @relation(fields: [sparePartId], references: [id])
  storeId         Int
  store           Store     @relation(fields: [storeId], references: [id])
  availableQty    Int       @default(0)
  lockedQty       Int       @default(0)
  minStock        Int       @default(0)
  pendingRequestQty Int     @default(0)
  inTransitQty    Int       @default(0)
  consumption30d  Int       @default(0)
  suggestedQty    Int       @default(0)
  expectedGap     Int       @default(0)
  reason          String
  // priority: URGENT | HIGH | MEDIUM | LOW
  priority        String
  // status: PENDING | CONVERTED | DISMISSED
  status          String    @default("PENDING")
  purchasePlanId  Int?
  purchasePlan    PurchasePlan? @relation(fields: [purchasePlanId], references: [id])
  convertedById   Int?
  convertedBy     User?     @relation("RestockConverter", fields: [convertedById], references: [id])
  convertedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([sparePartId, storeId, status])
}

model PurchasePlan {
  id              Int       @id @default(autoincrement())
  planNo          String    @unique
  // status: DRAFT | SUBMITTED | APPROVED | REJECTED | CANCELLED | PARTIAL_RECEIVED | FULL_RECEIVED
  status          String    @default("DRAFT")
  storeId         Int
  store           Store     @relation(fields: [storeId], references: [id])
  totalQty        Int       @default(0)
  estimatedCost   Float?    @default(0)
  remark          String?
  createdById     Int
  createdBy       User      @relation("PurchasePlanCreator", fields: [createdById], references: [id])
  submittedById   Int?
  submittedBy     User?     @relation("PurchasePlanSubmitter", fields: [submittedById], references: [id])
  submittedAt     DateTime?
  approvedById    Int?
  approvedBy      User?     @relation("PurchasePlanApprover", fields: [approvedById], references: [id])
  approvedAt      DateTime?
  rejectedById    Int?
  rejectedBy      User?     @relation("PurchasePlanRejector", fields: [rejectedById], references: [id])
  rejectedAt      DateTime?
  rejectReason    String?
  cancelledById   Int?
  cancelledBy     User?     @relation("PurchasePlanCanceller", fields: [cancelledById], references: [id])
  cancelledAt     DateTime?
  cancelReason    String?
  receivedQty     Int       @default(0)
  items           PurchasePlanItem[]
  suggestions     RestockSuggestion[]
  receipts        PurchaseReceipt[]
  inventoryLogs   InventoryLog[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model PurchasePlanItem {
  id              Int       @id @default(autoincrement())
  planId          Int
  plan            PurchasePlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  sparePartId     Int
  sparePart       SparePart @relation(fields: [sparePartId], references: [id])
  planQty         Int       @default(0)
  receivedQty     Int       @default(0)
  unitPrice       Float?    @default(0)
  remark          String?
  receiptItems    PurchaseReceiptItem[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([planId, sparePartId])
}

model PurchaseReceipt {
  id              Int       @id @default(autoincrement())
  receiptNo       String    @unique
  planId          Int
  plan            PurchasePlan @relation(fields: [planId], references: [id])
  storeId         Int
  store           Store     @relation(fields: [storeId], references: [id])
  // status: PENDING | CONFIRMED
  status          String    @default("PENDING")
  totalQty        Int       @default(0)
  remark          String?
  createdById     Int
  createdBy       User      @relation("PurchaseReceiptCreator", fields: [createdById], references: [id])
  confirmedById   Int?
  confirmedBy     User?     @relation("PurchaseReceiptConfirmer", fields: [confirmedById], references: [id])
  confirmedAt     DateTime?
  items           PurchaseReceiptItem[]
  inventoryLogs   InventoryLog[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model PurchaseReceiptItem {
  id              Int       @id @default(autoincrement())
  receiptId       Int
  receipt         PurchaseReceipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  planItemId      Int
  planItem        PurchasePlanItem @relation(fields: [planItemId], references: [id])
  sparePartId     Int
  sparePart       SparePart @relation(fields: [sparePartId], references: [id])
  quantity        Int       @default(0)
  unitPrice       Float?    @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([receiptId, planItemId])
}

model OperationLog {
  id            Int       @id @default(autoincrement())
  // LogAction 字符串：CREATE/UPDATE/DELETE/...
  action        String
  module        String
  targetId      Int?
  targetType    String?
  operatorId    Int
  operator      User      @relation(fields: [operatorId], references: [id])
  detail        String?
  oldValue      String?
  newValue      String?
  ipAddress     String?
  createdAt     DateTime  @default(now())
}
